# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Virtualenvs
.venv/
venv/
env/
.env

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store

# Pipeline artifacts — generated outputs and any sensitive input configs.
# The input/ directory itself is kept on clone via input/.gitkeep so the
# expected layout is visible; its contents are never committed.
input/*
!input/.gitkeep
output/

# Per-session governance logs. May reference internal context that doesn't
# belong in a public repo. Directory itself preserved via sessions/.gitkeep.
sessions/*
!sessions/.gitkeep

# Claude Code / agent scratch (kept local, not shared)
.claude/

# Local scratch / working drops (sample exports, cross-tool session logs, etc.)
tmp/

# Build / packaging artifacts
build/
dist/
*.egg-info/
*.egg

# Test + static-analysis caches and coverage reports
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.dmypy.json

# Notebook checkpoints (cheap insurance even with no notebooks today)
.ipynb_checkpoints/
